# OKX API - get from https://www.okx.com/account/my-api
# IMPORTANT: When creating API key, enable "Trade" permission and whitelist your IP
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Agent Wallet on X Layer
# MUST be funded with OKB (for gas) and USDT (for trading)
# The executor can spend current OKX-routed USDT or legacy X Layer USDT.
# Get OKB from OKX exchange, bridge to X Layer
AGENT_WALLET_ADDRESS=
PRIVATE_KEY=
AGENT_CHAIN_ID=196

# X Layer RPC
RPC_URL=https://rpc.xlayer.tech

# Agent behavior
RISK_TOLERANCE=conservative
SCAN_INTERVAL_MS=60000
MONITOR_INTERVAL_MS=120000
MAX_POSITION_SIZE_USDT=2
MAX_PORTFOLIO_SIZE_USDT=4

# Real judge demo cycle
# When enabled, the dashboard button can run a tiny real X Layer lifecycle:
# scan curated OKX tokens -> Guardian verdicts -> buy top safe candidates
# -> Sentinel monitor -> sell only the token that trips risk.
MAINNET_DEMO_ENABLED=false
# Set true only for a short judging window. Otherwise the route requires ADMIN_TOKEN.
# Public mode ignores arbitrary token overrides and only runs the configured token.
MAINNET_DEMO_PUBLIC=false
MAINNET_DEMO_CANDIDATES=XDOG:0x0cc24c51bf89c00c5affbfcf5e856c25ecbdb48e,OEOE:0x4c225fb675c0c475b53381463782a7f741d59763,FDOG:0x5839244eab49314bccc0fa76e3a081cb1a461111,DOGSHIT:0x70bf3e2b75d8832d7f790a87fffc1fa9d63dc5bb,TITAN:0xfdc4a45a4bf53957b2c73b1ff323d8cbe39118dd
MAINNET_DEMO_TOKEN_ADDRESS=
MAINNET_DEMO_TOKEN_SYMBOL=XDOG/FDOG
MAINNET_DEMO_AMOUNT_USDT=1
MAINNET_DEMO_BUY_COUNT=2
MAINNET_DEMO_MONITOR_MS=120000
MAINNET_DEMO_EXIT_DELAY_MS=45000
MAINNET_DEMO_COOLDOWN_MS=300000

# x402
X402_PRICE_PER_CHECK=0.005
# Real x402 settlement currently uses supported facilitator networks.
# Use Base + USDC for the paid API while the safety checks still target X Layer.
X402_ENABLED=true
X402_PAY_TO=
X402_NETWORK=base
X402_FACILITATOR_URL=https://x402.org/facilitator

# Optional buyer-side proof script:
# fund this wallet with USDC on X402_BUYER_NETWORK, then run:
# npm run x402:buy -w @rugnot/agent
X402_API_URL=http://localhost:3001/api/v1/security/check
X402_BUYER_PRIVATE_KEY=
X402_BUYER_NETWORK=base
X402_MAX_PAYMENT_USDC=0.02
X402_TEST_TOKEN_ADDRESS=0x779Ded0c9e1022225f8E0630b35a9b54bE713736

# AI chat
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Server
PORT=3001
ENABLE_MCP=false
# stdio is for local Claude Desktop/Cursor. http exposes POST /mcp on the API server.
MCP_TRANSPORT=stdio
STATE_PERSISTENCE_PATH=.rugnot-state.json
ADMIN_TOKEN=

# Production hardening
# Comma-separated list of dashboard origins allowed by CORS.
# Leave blank in dev (allows all origins). REQUIRED for public deployments.
DASHBOARD_ORIGIN=
# Set to "true" only when recording a demo. Leave "false" or unset in production
# so POST /api/demo/trigger is not exposed to the public internet.
ENABLE_DEMO=false
