# Dashboard production env — copy to .env.production and fill in real values
# (or set these directly in Vercel / Netlify project settings).
#
# Both URLs should point at the deployed agent backend (Phase 3 of the deploy plan).
# Use the same hostname for both — the agent attaches WebSockets to the same
# http.Server as Express, so /api/* and /ws share one origin.

VITE_API_URL=https://api.rugnot.example.com
VITE_WS_URL=wss://api.rugnot.example.com/ws
